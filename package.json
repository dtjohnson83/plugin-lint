{
  "name": "@danzus/plugin-lint",
  "version": "0.1.1",
  "description": "Linter for Claude Cowork plugin folders. Use when validating SKILL.md frontmatter, plugin.json structure, or trigger-phrase collisions. Do NOT use for general TypeScript linting or non-Claude plugin formats.",
  "bin": {
    "plugin-lint": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": "github:danzus/plugin-lint",
  "keywords": [
    "claude",
    "cowork",
    "plugin",
    "linter",
    "skill",
    "anthropic"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
